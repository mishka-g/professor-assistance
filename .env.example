# ---- Generation backend -------------------------------------------------
# mock  = no LLM needed, heuristic reviewer (free, runs anywhere) - good for testing the pipeline
# local = Ollama running on this Mac (free, private) - good for iterating
# gemini= Google AI Studio free tier (free cloud) - good for Intel Macs without Ollama
# api   = the professor's paid subscription (best quality) - use for the real drafts
MODEL_BACKEND=mock

# ---- Local (Ollama) -----------------------------------------------------
LOCAL_LLM=qwen2.5:14b-instruct
OLLAMA_HOST=http://localhost:11434

# ---- Gemini (free cloud — good for Intel Macs without Ollama) ----------
# MODEL_BACKEND=gemini
# GEMINI_API_KEY=...             # from https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-2.0-flash

# ---- API path -----------------------------------------------------------
# API_PROVIDER=openai            # openai | anthropic
# API_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Retrieval / embeddings (always local, private) ---------------------
# Default embedder is Chroma's built-in ONNX model (no torch, quiet, works everywhere).
# Set USE_ST_EMBEDDER=1 to use sentence-transformers + EMBEDDING_MODEL below instead
# (better model, but needs a working torch — e.g. Apple Silicon). If you switch this,
# re-run `profa ingest` so the corpus is re-embedded with the new model.
USE_ST_EMBEDDER=0
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RETRIEVAL_TOP_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
