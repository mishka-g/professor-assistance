# ---- Generation backend -------------------------------------------------
# mock   = no LLM needed, heuristic reviewer (free, runs anywhere) — pipeline tests / eval CI
# gemini = Google AI Studio free tier — **recommended for quality demos**
# local  = Ollama on this machine (free, private) — offline alternative to Gemini
# api    = paid OpenAI/Anthropic — best quality for real drafts
#
# Demo-quality profile (recommended):
#   MODEL_BACKEND=gemini
#   GEMINI_API_KEY=...   # https://aistudio.google.com/apikey
MODEL_BACKEND=mock

# ---- Gemini (recommended for quality demos) -----------------------------
# MODEL_BACKEND=gemini
# GEMINI_API_KEY=...             # from https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-2.0-flash

# ---- Local (Ollama) — offline alternative -------------------------------
LOCAL_LLM=qwen2.5:14b-instruct
OLLAMA_HOST=http://localhost:11434

# ---- API path -----------------------------------------------------------
# API_PROVIDER=openai            # openai | anthropic
# API_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Retrieval / embeddings (always local, private) ---------------------
# Default embedder is Chroma's built-in ONNX model (no torch, quiet, works everywhere).
# Set USE_ST_EMBEDDER=1 to use sentence-transformers + EMBEDDING_MODEL below instead
# (better model, but needs a working torch — e.g. Apple Silicon). If you switch this,
# re-run `profa ingest` so the corpus is re-embedded with the new model.
USE_ST_EMBEDDER=0
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RETRIEVAL_TOP_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
